{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "vcreations-frontend/build/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(products|admin|orders|auth|health|cart|config)(/.*)?", "dest": "api/index.js" },
    { "src": "/static/(.*)", "dest": "vcreations-frontend/build/static/$1" },
    { "src": "/favicon\\.ico", "dest": "vcreations-frontend/build/favicon.ico" },
    { "src": "/manifest\\.json", "dest": "vcreations-frontend/build/manifest.json" },
    { "src": "/(.*)", "dest": "vcreations-frontend/build/index.html" }
  ]
}
