{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd vcreations-frontend && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd vcreations-backend && node server.js",
    "numReplicas": 1,
    "healthcheckPath": "/"
  }
}
